<!--
=============================================================================
 default/data/ui/views/nucleus_epss_score.xml
 Nucleus Security for Splunk App
 EPSS Score Overview
=============================================================================
-->

<dashboard version="1.1" theme="light">
  <label>📈 EPSS Score Analysis</label>

  <!-- =============================================================== -->
  <!-- BASE SEARCH                                                      -->
  <!-- Data expected from Nucleus Findings with EPSS enrichment        -->
  <!-- sourcetype example: nucleus:findings                            -->
  <!-- =============================================================== -->
  <search>
    <query>
      index=nucleus sourcetype=nucleus:findings
    </query>
  </search>

  <!-- =============================================================== -->
  <!-- EPSS COVERAGE SUMMARY                                            -->
  <!-- =============================================================== -->
  <row>
    <panel>
      <title>📊 Total Findings</title>
      <single>
        <search>
          <query>
            index=nucleus sourcetype=nucleus:findings
            | stats count as total_findings
          </query>
        </search>
      </single>
    </panel>

    <panel>
      <title>🧠 EPSS Enriched Findings</title>
      <single>
        <search>
          <query>
            index=nucleus sourcetype=nucleus:findings
            | where isnotnull(epss_score)
            | stats count as epss_enriched
          </query>
        </search>
      </single>
    </panel>

    <panel>
      <title>🚨 High Probability (EPSS ≥ 0.7)</title>
      <single>
        <search>
          <query>
            index=nucleus sourcetype=nucleus:findings
            | where epss_score >= 0.7
            | stats count as high_probability_findings
          </query>
        </search>
      </single>
    </panel>
  </row>

  <!-- =============================================================== -->
  <!-- EPSS DISTRIBUTION                                                -->
  <!-- =============================================================== -->
  <row>
    <panel>
      <title>📊 EPSS Distribution</title>
      <chart>
        <search>
          <query>
            index=nucleus sourcetype=nucleus:findings
            | where isnotnull(epss_score)
            | bucket epss_score span=0.1
            | stats count by epss_score
            | sort epss_score
          </query>
        </search>
        <option name="charting.chart">column</option>
      </chart>
    </panel>
  </row>

  <!-- =============================================================== -->
  <!-- EPSS VS SEVERITY MISMATCH                                        -->
  <!-- =============================================================== -->
  <row>
    <panel>
      <title>⚖️ High EPSS / Low Severity Mismatch</title>
      <table>
        <search>
          <query>
            index=nucleus sourcetype=nucleus:findings
            | where epss_score >= 0.7 AND severity!="Critical" AND severity!="High"
            | table asset_name cve_id severity epss_score
            | sort - epss_score
          </query>
        </search>
        <option name="wrap">true</option>
        <option name="count">100</option>
      </table>
    </panel>
  </row>

  <!-- =============================================================== -->
  <!-- EPSS TREND OVER TIME                                             -->
  <!-- =============================================================== -->
  <row>
    <panel>
      <title>📉 High EPSS Findings Trend</title>
      <chart>
        <search>
          <query>
            index=nucleus sourcetype=nucleus:findings
            | where epss_score >= 0.7
            | timechart span=1d count
          </query>
        </search>
        <option name="charting.chart">line</option>
      </chart>
    </panel>
  </row>

</dashboard>
